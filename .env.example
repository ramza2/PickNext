# Application
APP_NAME=PickNext
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SQL_ECHO=false

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security (change in production)
SECRET_KEY=change-me-to-a-long-random-string

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=picknext
POSTGRES_USER=picknext
POSTGRES_PASSWORD=change-me-picknext-password

# Full database URL (overrides individual POSTGRES_* when set).
# If set manually, URL-encode special characters in the password (@, :, /, etc).
# Prefer POSTGRES_* fields — the app builds a safe URL via SQLAlchemy URL.create.
# DATABASE_URL=postgresql+psycopg://picknext:change-me-picknext-password@localhost:5432/picknext

# Docker Compose published ports
BACKEND_PORT=8000
POSTGRES_PUBLISH_PORT=5432

# Frontend (Compose / production build)
# VITE_* values are embedded in the browser bundle — never put secrets here.
VITE_API_BASE_URL=/api/v1
PICKNEXT_FRONTEND_IMAGE=picknext-frontend:latest
PICKNEXT_FRONTEND_PORT=5183

# DPL-2 isolated Compose override (compose.local.yaml) — Loopback only
# DPL2_BACKEND_PORT=8012
# DPL2_POSTGRES_PUBLISH_PORT=15432

# DPL-3 Traefik (compose.traefik.yaml) — public Host
# Do NOT combine compose.local.yaml with compose.traefik.yaml.
# SSH passwords and remote sudo passwords must never be stored here.
PICKNEXT_HOST=picknext.ramza.duckdns.org

# Seed (development defaults)
SEED_USER_EMAIL=dev@picknext.local
SEED_USER_DISPLAY_NAME=Dev User
SEED_USER_PASSWORD=dev-password-change-me

# TMDB (Read Access Token preferred; API Key is fallback. Never put secrets in Frontend.)
# include_adult is fixed to true in Backend code — not configurable here.
TMDB_API_KEY=
TMDB_API_READ_ACCESS_TOKEN=
TMDB_LANGUAGE=ko-KR
TMDB_REGION=KR
# Optional overrides (safe defaults exist in Settings):
# TMDB_API_BASE_URL=https://api.themoviedb.org/3
# TMDB_REQUEST_TIMEOUT_SECONDS=10
# TMDB_CONFIGURATION_TTL_SECONDS=86400
# TMDB_STATUS_TTL_SECONDS=60
# TMDB_POSTER_SIZE=w500
# TMDB_BACKDROP_SIZE=w780
# TMDB_PROFILE_SIZE=w185